#!/bin/bash
# Post-commit hook: auto-generate a changeset for modified @bcl32/* packages.
# Amends the commit to include the changeset file.
# PAI_SKIP_CHANGESET prevents infinite recursion when amending.

[ "$PAI_SKIP_CHANGESET" = "1" ] && exit 0

# Skip merge commits and CI version commits
commit_msg=$(git log -1 --format=%s)
[[ "$commit_msg" == "chore: version packages"* ]] && exit 0
[ "$(git rev-parse -q --verify MERGE_HEAD 2>/dev/null)" ] && exit 0

# Known workspace packages
PACKAGES=(utils data-utils hooks charts datatable filters forms navigation themes)

# Detect which packages were modified in this commit
changed=()
for pkg in "${PACKAGES[@]}"; do
  if git diff-tree --no-commit-id --name-only -r HEAD | grep -q "^${pkg}/"; then
    changed+=("$pkg")
  fi
done

# Nothing to do if no packages were touched
[ ${#changed[@]} -eq 0 ] && exit 0

# Skip if there's already a changeset file staged in this commit
# (user created one manually via pnpm changeset)
if git diff-tree --no-commit-id --name-only -r HEAD | grep -q '^\.changeset/.*\.md$'; then
  # Check it's not just the README
  non_readme=$(git diff-tree --no-commit-id --name-only -r HEAD | grep '^\.changeset/.*\.md$' | grep -v 'README.md')
  [ -n "$non_readme" ] && exit 0
fi

# Generate a short random name for the changeset file
slug=$(head -c 8 /dev/urandom | od -An -tx1 | tr -d ' \n' | head -c 8)
changeset_file=".changeset/auto-${slug}.md"

# Build the changeset YAML frontmatter
{
  echo "---"
  for pkg in "${changed[@]}"; do
    echo "\"@bcl32/${pkg}\": patch"
  done
  echo "---"
  echo ""
  echo "$commit_msg"
} > "$changeset_file"

# Stage and amend the commit to include the changeset
git add "$changeset_file"
PAI_SKIP_CHANGESET=1 git commit --amend --no-edit

echo "Auto-changeset: created ${changeset_file} for ${changed[*]}"
