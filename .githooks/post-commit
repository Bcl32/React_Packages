#!/bin/bash
# Auto-bump: runs after commit, amends to include version bumps.
# PAI_SKIP_BUMP prevents infinite recursion when amending.
[ "$PAI_SKIP_BUMP" = "1" ] && exit 0

# Write commit message to temp file for PackageManager
tmpfile=$(mktemp)
git log -1 --format=%B > "$tmpfile"

# Run bump (modifies package.json + CHANGELOG, stages them)
bun ~/.claude/tools/PackageManager.ts bump "$tmpfile"

# If there are staged changes from the bump, amend the commit
if ! git diff --cached --quiet; then
  PAI_SKIP_BUMP=1 git commit --amend --no-edit
fi

rm -f "$tmpfile"
