{
  "name": "@bcl32/charts",
  "version": "3.1.0",
  "description": "Custom recharts chart components",
  "author": "",
  "license": "ISC",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./Charts": {
      "types": "./dist/Charts.d.ts",
      "import": "./dist/Charts.js"
    },
    "./TimeSeriesChart": {
      "types": "./dist/TimeSeriesChart.d.ts",
      "import": "./dist/TimeSeriesChart.js"
    },
    "./StatCard": {
      "types": "./dist/StatCard.d.ts",
      "import": "./dist/StatCard.js"
    },
    "./DonutChart": {
      "types": "./dist/DonutChart.d.ts",
      "import": "./dist/DonutChart.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Bcl32/React_Packages.git",
    "directory": "charts"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.12.0"
  },
  "dependencies": {
    "@bcl32/utils": "workspace:^2.5.0",
    "@bcl32/hooks": "workspace:^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
